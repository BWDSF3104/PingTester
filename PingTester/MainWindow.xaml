<Window x:Class="PingTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PingTester"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="650" Width="900" Closing="Window_Closing" Loaded="Window_Loaded">
    <Grid Margin="2,0,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!-- [2026-04-23 修正] 左パネル: 手動追加/削除/変更・ポート設定・ポートマッピング取得を削除
                               RoomId/MyName 編集と外部エンドポイント表示を追加 -->
        <Grid Margin="0,0,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel>
                <!-- グローバルIP表示 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="グローバルIP" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBox x:Name="gIPTextBox" Text="{Binding GIPStr}" Width="150" Margin="0,0,5,0" IsReadOnly="True"/>
                    <Button x:Name="CopyButton" Content="コピー" Click="CopyButton_Click"/>
                </StackPanel>
                <!-- 外部エンドポイント（STUN 取得・OS 自動割り当てポートを含む） -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="外部エンドポイント" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding ExternalEPStr}" Width="150" IsReadOnly="True"/>
                </StackPanel>
                <!-- Ping 送信回数 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Ping送信回数" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding NumberOfSend}" x:Name="numberOfSendBox" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <Button x:Name="numberOfSendChangeButton" Content="変更" Click="NumberOfSendChangeButton_Click"/>
                </StackPanel>
                <!-- ルームID（通常変更不要） -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="ルームID" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding RoomId, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                </StackPanel>
                <TextBlock Text="※ ルームIDは通常変更不要です" FontSize="10" Foreground="Gray" Margin="0,0,0,10"/>
                <!-- 自分の名前 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="自分の名前" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding MyName, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                </StackPanel>
                <!-- MQTT 接続状態 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="MQTT状態: " VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MqttStatusText}" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
                <!-- MQTT リトライ回数 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="MQTTリトライ回数" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MqttRetryCount}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <Button Content="変更" Click="MqttRetryCountChangeButton_Click"/>
                </StackPanel>
                <!-- MQTT 再接続（RoomId/MyName 変更後に押す） -->
                <Button x:Name="reconnectButton" Content="MQTT再接続" Margin="0,0,0,10" Click="ReconnectButton_Click"/>

                <TextBlock Text="接続済みメンバー"/>
            </StackPanel>

            <!-- [2026-04-23 修正] 外部ポート列を読み取り専用表示に変更（MQTT 自動入力）
                                   SelectionChanged ハンドラを削除 -->
            <ListView x:Name="checkListView" DataContext="{Binding IPAndNames}" ItemsSource="{Binding Mode=OneWay}" Grid.Row="1" SelectionChanged="CheckListView_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="名前" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="IPアドレス" DisplayMemberBinding="{Binding IP}"/>
                        <GridViewColumn Header="外部ポート" DisplayMemberBinding="{Binding ExternalPort}" Width="80"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Grid.Row="2">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="addButton" Content="追加" Margin="0,0,5,0" Click="AddButton_Click"/>
                    <Button x:Name="deleteButton" Content="削除" IsEnabled="False" Click="DeleteButton_Click" Margin="0,0,5,0"/>
                    <Button x:Name="modButton" Content="変更" IsEnabled="False" Click="ModButton_Click"/>
                </StackPanel>
                <CheckBox x:Name="autoSaveEnable" Content="設定自動保存" IsChecked="True" Margin="0,0,0,10"/>
                <!-- [2026-04-23 追加] ルーム内の残留 retain メッセージを管理する画面を開く -->
                <Button x:Name="retainManageButton" Content="Retain管理" Margin="0,0,0,5"
                        Click="RetainManageButton_Click"/>
                <Button x:Name="startButton" Content="開始" Click="StartButton_Click" IsEnabled="{Binding PossibleExecute}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>
            <ListView DataContext="{Binding IPAndNames}" ItemsSource="{Binding Mode=OneWay}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="名前" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="IPアドレス" DisplayMemberBinding="{Binding IP}"/>
                        <GridViewColumn Header="最小値(ms)" DisplayMemberBinding="{Binding Min}"/>
                        <GridViewColumn Header="最大値(ms)" DisplayMemberBinding="{Binding Max}"/>
                        <GridViewColumn Header="平均値(ms)" DisplayMemberBinding="{Binding Average}"/>
                        <GridViewColumn Header="前回平均値(ms)" DisplayMemberBinding="{Binding PrevAverage}"/>
                        <GridViewColumn Header="総平均値(ms)" DisplayMemberBinding="{Binding AllAverage}"/>
                        <!-- [2026-04-23 追加] 計測時に実際に使用した送信先ポートを表示 -->
                        <GridViewColumn Header="使用ポート" DisplayMemberBinding="{Binding UsedPort}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Grid Grid.Row="1">
                <!-- [2026-04-12 追加] ログ表示領域。MainProcess.LogEntries に新しいログが先頭挿入される -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="ログ" FontWeight="Bold" Margin="4,2"/>
                <ListBox Grid.Row="1"
             ItemsSource="{x:Static local:MainProcess.LogEntries}"
             FontFamily="Consolas"
             FontSize="11"
             VirtualizingPanel.IsVirtualizing="True"
             VirtualizingPanel.VirtualizationMode="Recycling"
             ScrollViewer.HorizontalScrollBarVisibility="Auto"
             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Grid>

    </Grid>
</Window>
